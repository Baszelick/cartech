generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum CarStatus {
  STOCK
  ISSUED
}


model Car {

  id Int @id @default(autoincrement())

  vin String @unique

  brand String

  model String

  color String

  arrivalDate DateTime

  batteryChecks BatteryCheck[]

  status CarStatus @default(STOCK)

  psoCompletedAt DateTime?

  issuedAt DateTime?

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt

  batteryLastCheckAt DateTime?

  nextBatteryCheckAt DateTime?
}

model BatteryCheck {
  id Int @id @default(autoincrement())

  checkedAt DateTime @default(now())

  voltage Float?

  comment String?

  carId Int

  car Car @relation(fields: [carId],references: [id])
}